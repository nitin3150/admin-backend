# ============================================
# SmartBag Admin Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=Development

# MongoDB
MONGO_URI=mongodb://mongo:27017
DB_NAME=smartbag

# JWT
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL (inventory layer)
POSTGRES_URL=postgresql+asyncpg://smartbag:smartbag_secret@postgres:5432/smartbag_inventory

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# Celery (background tasks)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Ola Maps
OLA_KRUTRIM_API_KEY=
OLA_BASE_URL=https://api.olamaps.io/places/v1

# Elasticsearch (optional)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=smartbag

# Monitoring
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60
